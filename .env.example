# =========================================================================
# AI Recruiter - Environment Configuration Template
# Copy this file to '.env' and fill in your actual values before running.
# =========================================================================

# Database URL
# If empty or omitted, the application automatically uses a local SQLite file (recruiter.db)
DATABASE_URL=sqlite:///./recruiter.db
# DATABASE_URL=postgresql://user:password@localhost:5432/recruiter_db

# Security & JWT Credentials
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Google Gemini API Configuration (Mandatory for AI features)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# Pinecone Vector DB Configuration (Optional - Local vector index used as fallback if blank)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-east-1
PINECONE_INDEX=recruiter-fingerprints

# Suppabase / Claude configurations (Optional if Node server is used)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
ANTHROPIC_API_KEY=your-anthropic-claude-api-key
JWT_SECRET=your-jwt-secret-key
PORT=8000

# SMTP Configuration for sending actual emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
